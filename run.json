{
  "common": {
    "DATA_DIR": "data",
    "ALL_FILE": "catalogs-all.pkl",
    "ALL_FILE_REMOTE": "https://hapi-server.org/meta/catalogs-all.pkl"
  },
  "abouts": {
    "repo_url": "https://github.com/hapi-server/servers",
    "repo_dir": "servers",
    "files": [
      "abouts.json",
      "abouts-dev.json",
      "abouts-test.json"
    ],
    "simulate": false,
    "timeout": 10,
    "retries": 3
  },
  "catalogs": {
    "debug": false,
    "max_datasets": null,
    "timeout": 60,
    "max_workers": 10,
    "servers_repo": "servers",
    "about_files": [
      "abouts.json",
      "abouts-test.json"
    ]
  },
  "availabilities": {
    "debug_layout": false,
    "debug_svglinks": false,
    "max_datasets": null,
    "lines_per_plot": 50,
    "savefig_fmts": [
      "svg",
      "png"
    ],
    "dpi": 300,
    "fig_width_pixels": 3840,
    "fig_height_pixels": 2160
  },
  "relations": {
    "all": true,
    "server_id": "INTERMAGNET",
    "observatory": "aae"
  },
  "table": {
    "dicts2table": {
      "dataset": {
        "name": "hapi.all.datasets",
        "out_dir": "data/table",
        "use_all_attributes": true,
        "path_type": "list",
        "omit_attributes": [
          "x_customRequestOptions",
          "parameters"
        ],
        "paths": {
          "/": {
            "server": null,
            "dataset": null,
            "title": null,
            "description": null,
            "startDate": null,
            "x_startDate": null,
            "stopDate": null,
            "x_stopDate": null,
            "cadence": null,
            "timeStampLocation": null,
            "sampleStartDate": null,
            "sampleStopDate": null,
            "resourceID": null
          }
        }
      },
      "parameter": {
        "name": "hapi.all.parameters",
        "out_dir": "data/table",
        "use_all_attributes": true,
        "paths": {
          "/": {
            "server": null,
            "dataset": null,
            "parameter": null,
            "startDate": null,
            "x_startDate": null,
            "stopDate": null,
            "x_stopDate": null,
            "cadence": null,
            "type": null,
            "units": null,
            "length": null
          }
        }
      }
    },
    "omits": [
      "info/HAPI",
      "info/status",
      "info/definitions"
    ]
  },
  "spase": {
    "info_path": "infos",
    "reread_info_comment": "Set to true to read info from data/info directory instead of from the catalog. Use this for testing to avoid having to re-run the catalog step after making changes to the info files.",
    "reread_info": false,
    "config": {
      "Spase": {
        "SchemaURL": "http://www.spase-group.org/data/schema",
        "Version": "2.7.0"
      },
      "AccessInformation": [
        {
          "RepositoryID": "spase://SMWG/Repository/?",
          "Availability": "Online",
          "AccessRights": "Open",
          "Format": ["CSV", "Binary", "JSON"],
          "Acknowledgement": "",
          "AccessURL": {
            "URL": "",
            "Style": "HAPI",
            "ProductKey": null,
            "Description": "Web Service to this data using the HAPI interface."
          }
        },
        {
          "RepositoryID": "spase://SMWG/Repository/?",
          "Availability": "Online",
          "AccessRights": "Open",
          "Format": ["PNG", "SVG", "PDF"],
          "Acknowledgement": "",
          "AccessURL": {
            "URL": "https://hapi-server.org/servers/#server={server}&dataset={dataset}",
            "Style": "HAPI",
            "ProductKey": null,
            "Description": "Alternative web service to this data. Contact: https://github.com/hapi-server/server-ui/issues"
          }
        },
        {
          "RepositoryID": "spase://SMWG/Repository/?",
          "Availability": "Online",
          "AccessRights": "Open",
          "Encoding": "ASCII",
          "Acknowledgement": "",
          "AccessURL": {
            "Name": "CDAWeb HAPI Script in Multiple Languages",
            "URL": "https://hapi-server.org/servers/#server={server}&dataset={dataset}&return=script",
            "Style": "HAPI",
            "ProductKey": null,
            "Description": "Web Service user interface that generates scripts in {languages} to access this dataset. See https://hapi-server.org/servers/api for the script generation API. Contact: https://github.com/hapi-server/server-ui/issues"
          }
        }
      ],
      "formatMap": {
        "csv": "CSV",
        "json": "JSON",
        "binary": "Binary"
      },
      "hapi2spase": {
        "dataset": {
          "id": "ProviderResourceName",
          "title": "ResourceHeader/ResourceName",
          "info/description": "ResourceHeader/Description",
          "info/startDate": "TemporalDescription/TimeSpan/StartDate",
          "info/stopDate": "TemporalDescription/TimeSpan/StopDate",
          "info/cadence": "TemporalDescription/Cadence",
          "info/warning": "Caveats"
        },
        "parameter": {
          "name": ["Name", "ParameterKey"],
          "description": "Description",
          "units": "Units"
        }
      }
    }
  }
}
